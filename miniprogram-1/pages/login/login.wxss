.page {
  min-height: 100vh;
  padding: 32rpx 24rpx;
  background:
    radial-gradient(circle at top left, rgba(18, 60, 99, 0.18), transparent 28%),
    linear-gradient(180deg, #f6fbff 0%, #eef3f8 100%);
}

.hero-card,
.form-card {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
  color: #ffffff;
}

.hero-eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  opacity: 0.76;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.9;
}

.form-card {
  margin-top: 24rpx;
}

.field + .field {
  margin-top: 22rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.input {
  height: 88rpx;
  margin-top: 14rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.primary-btn {
  height: 88rpx;
  margin-top: 32rpx;
  border-radius: 22rpx;
  line-height: 88rpx;
  text-align: center;
  color: #ffffff;
  background: #123c63;
}

.link-row {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-top: 24rpx;
  font-size: 24rpx;
}

.link-text {
  color: #64748b;
}

.link-btn {
  color: #123c63;
  font-weight: 700;
}
