<view class="page">
  <view class="profile-card">
    <view class="profile-eyebrow">PERSONAL CENTER</view>
    <view class="profile-name">{{profile.name}}</view>
    <view class="profile-meta">{{profile.department}}</view>
    <view class="profile-meta">{{profile.className}}</view>
    <view class="profile-id">学号：{{profile.studentId}}</view>
  </view>

  <view class="section">
    <view class="section-title">常用入口</view>
    <view class="section-desc">统一放置个人高频使用的业务入口。</view>
    <view class="shortcut-list">
      <view
        wx:for="{{shortcuts}}"
        wx:key="title"
        class="shortcut-card"
        data-path="{{item.path}}"
        bindtap="onShortcutTap"
      >
        <view>
          <view class="shortcut-title">{{item.title}}</view>
          <view class="shortcut-desc">{{item.desc}}</view>
        </view>
        <view class="shortcut-action">进入</view>
      </view>
    </view>
  </view>

  <view class="section section-last">
    <view class="section-title">账号信息</view>
    <view class="info-list">
      <view wx:for="{{serviceInfo}}" wx:key="label" class="info-item">
        <view class="info-label">{{item.label}}</view>
        <view class="info-value">{{item.value}}</view>
      </view>
    </view>
  </view>
</view>
