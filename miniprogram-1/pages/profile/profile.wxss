.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(18, 60, 99, 0.14), transparent 30%),
    linear-gradient(180deg, #f6fbff 0%, #eef3f8 100%);
}

.profile-card,
.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.profile-card {
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
  color: #ffffff;
}

.profile-eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  opacity: 0.72;
}

.profile-name {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.profile-meta,
.profile-id {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.section {
  margin-top: 20rpx;
}

.section-last {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc,
.shortcut-desc,
.info-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.shortcut-list,
.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.shortcut-card,
.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.shortcut-title,
.info-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.shortcut-action {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #123c63;
  background: rgba(18, 60, 99, 0.12);
}
