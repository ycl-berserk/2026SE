<view class="page">
  <view class="form-card">
    <view class="section-title">账号注册</view>
    <view class="section-desc">注册后将生成独立账号，后续请假、通知、党团事务等数据都会与该账号绑定。</view>

    <view class="field">
      <view class="label">姓名</view>
      <input class="input" data-field="realName" placeholder="请输入姓名" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">学号</view>
      <input class="input" data-field="studentNo" placeholder="请输入学号" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">密码</view>
      <input class="input" data-field="password" password placeholder="请输入密码" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">确认密码</view>
      <input class="input" data-field="confirmPassword" password placeholder="请再次输入密码" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">身份类型</view>
      <picker range="{{authTypeOptions}}" range-key="label" value="{{authTypeIndex}}" bindchange="onAuthTypeChange">
        <view class="picker">{{authTypeOptions[authTypeIndex].label}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">年级</view>
      <input class="input" data-field="grade" placeholder="如 2023" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">专业</view>
      <input class="input" data-field="major" placeholder="请输入专业" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">班级</view>
      <input class="input" data-field="className" placeholder="请输入班级" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">手机号</view>
      <input class="input" data-field="phone" placeholder="请输入手机号" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">邮箱</view>
      <input class="input" data-field="email" placeholder="请输入邮箱" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">生源地</view>
      <input class="input" data-field="hometown" placeholder="请输入生源地" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">宿舍</view>
      <input class="input" data-field="dormitory" placeholder="请输入宿舍信息" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="label">个人介绍</view>
      <textarea class="textarea" data-field="bio" maxlength="300" placeholder="介绍一下自己" bindinput="onFieldInput" />
    </view>

    <button class="primary-btn" loading="{{submitting}}" bindtap="onSubmit">完成注册</button>
  </view>
</view>
