.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.16), transparent 24%),
    #f3f7fb;
}

.form-card {
  padding: 28rpx 24rpx 36rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.field {
  margin-top: 22rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.input,
.picker,
.textarea {
  width: 100%;
  margin-top: 14rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.input,
.picker {
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
  padding: 22rpx 24rpx;
}

.primary-btn {
  height: 88rpx;
  margin-top: 32rpx;
  border-radius: 22rpx;
  line-height: 88rpx;
  color: #ffffff;
  background: #123c63;
}
