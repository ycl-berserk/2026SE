<view class="page">
  <scroll-view class="page-scroll" scroll-y enable-flex>
    <view class="hero-card">
      <view class="hero-top">
        <view>
          <view class="hero-eyebrow">{{banner.eyebrow}}</view>
          <view class="hero-title">{{banner.title}}</view>
          <view class="hero-subtitle">{{banner.subtitle}}</view>
        </view>
        <view class="hero-badge">{{banner.badge}}</view>
      </view>

      <view class="hero-meta">
        <view class="hero-meta-item" wx:for="{{banner.meta}}" wx:key="label">
          <view class="hero-meta-value">{{item.value}}</view>
          <view class="hero-meta-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">Quick Entry</view>
        <view class="section-desc">Core student-service entry points.</view>
      </view>

      <view class="entry-grid">
        <view
          class="entry-card"
          wx:for="{{quickEntries}}"
          wx:key="title"
          data-path="{{item.path}}"
          data-title="{{item.title}}"
          bindtap="handleEntryTap"
        >
          <view class="entry-icon">{{item.icon}}</view>
          <view class="entry-title">{{item.title}}</view>
          <view class="entry-desc">{{item.desc}}</view>
          <view class="entry-tag {{item.status === 'Ready' ? 'is-ready' : 'is-pending'}}">{{item.status}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">My Todo</view>
        <view class="section-desc">Aggregated values from backend home data.</view>
      </view>

      <view class="stats-row">
        <view class="stat-card" wx:for="{{todoStats}}" wx:key="label">
          <view class="stat-value">{{item.value}}</view>
          <view class="stat-label">{{item.label}}</view>
          <view class="stat-hint">{{item.hint}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">Latest Notices</view>
        <view class="section-desc">Empty is acceptable in the current demo backend.</view>
      </view>

      <view class="notice-list">
        <view wx:if="{{latestNotices.length}}">
          <view class="notice-card" wx:for="{{latestNotices}}" wx:key="title">
            <view class="notice-top">
              <view class="notice-tag">{{item.tag}}</view>
              <view class="notice-date">{{item.date}}</view>
            </view>
            <view class="notice-title">{{item.title}}</view>
            <view class="notice-summary">{{item.summary}}</view>
          </view>
        </view>
        <view wx:else class="empty-card">No notice data available.</view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">Downloads</view>
        <view class="section-desc">Current backend does not expose real download links.</view>
      </view>

      <view class="download-list">
        <view
          class="download-card"
          wx:for="{{downloads}}"
          wx:key="name"
          data-name="{{item.name}}"
          bindtap="handleDownloadTap"
        >
          <view>
            <view class="download-name">{{item.name}}</view>
            <view class="download-desc">{{item.desc}}</view>
          </view>
          <view class="download-action">Open</view>
        </view>
      </view>
    </view>

    <view class="section section-last">
      <view class="section-head">
        <view class="section-title">Scope</view>
        <view class="section-desc">Current demo focuses on home, knowledge and party progress.</view>
      </view>

      <view class="highlight-list">
        <view class="highlight-item" wx:for="{{serviceHighlights}}" wx:key="title">
          <view class="highlight-title">{{item.title}}</view>
          <view class="highlight-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
