.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.22), transparent 28%),
    linear-gradient(180deg, #f6fbff 0%, #f2f5f9 45%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx 48rpx;
}

.hero-card {
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
  color: #ffffff;
  box-shadow: 0 24rpx 48rpx rgba(18, 60, 99, 0.18);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.72;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.88;
}

.hero-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.12);
}

.hero-meta {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 30rpx;
}

.hero-meta-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero-meta-value {
  font-size: 34rpx;
  font-weight: 700;
}

.hero-meta-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.8;
}

.section {
  margin-top: 28rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 40rpx rgba(30, 41, 59, 0.06);
  backdrop-filter: blur(8rpx);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.entry-card {
  position: relative;
  min-height: 196rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
}

.entry-icon {
  font-size: 40rpx;
}

.entry-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.entry-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #475569;
}

.entry-tag {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.is-ready {
  background: rgba(15, 118, 110, 0.14);
  color: #0f766e;
}

.is-pending {
  background: rgba(217, 119, 6, 0.14);
  color: #b45309;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.stat-card {
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #334155;
}

.stat-hint {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #94a3b8;
}

.notice-list,
.download-list,
.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-card,
.download-card,
.highlight-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.notice-top,
.download-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.notice-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #155e75;
  background: rgba(34, 211, 238, 0.18);
}

.notice-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.notice-title,
.download-name,
.highlight-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.notice-title {
  margin-top: 14rpx;
}

.notice-summary,
.download-desc,
.highlight-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #475569;
}

.download-action {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #0f766e;
  background: rgba(16, 185, 129, 0.14);
}
