.page {
  min-height: 100vh;
  background: #f3f6fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.tab {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #334155;
  font-size: 24rpx;
  white-space: nowrap;
}

.tab.active {
  background: #0f766e;
  color: #ffffff;
}

.list {
  padding-bottom: 140rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.status {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.status-0 {
  color: #b45309;
  background: #ffedd5;
}

.status-2 {
  color: #0f766e;
  background: #ccfbf1;
}

.status-3 {
  color: #be123c;
  background: #ffe4e6;
}

.card-reason,
.card-time,
.card-submit {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
}

.empty {
  margin-top: 80rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
}

.create-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: #0f766e;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
}
