.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(249, 115, 22, 0.15), transparent 26%),
    #f8f5f2;
}

.summary-card,
.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.summary-top,
.timeline-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-name,
.section-title,
.timeline-title,
.reminder-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.summary-meta,
.summary-info,
.timeline-time,
.timeline-desc,
.reminder-deadline,
.reminder-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.summary-stage,
.timeline-status {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.summary-stage,
.timeline-status.done {
  color: #0f766e;
  background: rgba(16, 185, 129, 0.14);
}

.timeline-status.current {
  color: #b45309;
  background: rgba(245, 158, 11, 0.16);
}

.timeline-status.pending {
  color: #64748b;
  background: rgba(148, 163, 184, 0.14);
}

.summary-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #334155;
}

.section {
  margin-top: 20rpx;
}

.section-last {
  margin-bottom: 24rpx;
}

.timeline {
  margin-top: 24rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
}

.timeline-axis {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 28rpx;
}

.timeline-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #cbd5e1;
}

.timeline-dot.done {
  background: #10b981;
}

.timeline-dot.current {
  background: #f59e0b;
}

.timeline-line {
  flex: 1;
  width: 4rpx;
  margin: 8rpx 0;
  background: #e2e8f0;
}

.timeline-card,
.reminder-card {
  flex: 1;
  margin-bottom: 20rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}
