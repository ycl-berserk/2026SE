.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.16), transparent 24%),
    #f3f7fb;
}

.search-card,
.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.search-title,
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.search-desc,
.section-desc,
.article-summary,
.article-answer,
.template-desc,
.empty-card {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.search-input {
  height: 84rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.chips-scroll {
  margin: 20rpx 0;
  white-space: nowrap;
}

.chips-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 24rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.12);
  color: #475569;
  font-size: 24rpx;
}

.chip-active {
  background: #123c63;
  color: #ffffff;
}

.section {
  margin-top: 20rpx;
}

.section-last {
  margin-bottom: 24rpx;
}

.article-list,
.template-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.article-card,
.template-card,
.empty-card {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.article-head,
.template-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.article-category,
.template-format,
.article-source {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.article-category {
  color: #0f766e;
  background: rgba(20, 184, 166, 0.14);
}

.article-source {
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.12);
}

.article-title,
.template-name {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.template-format {
  flex-shrink: 0;
  align-self: flex-start;
  color: #155e75;
  background: rgba(34, 211, 238, 0.14);
}
