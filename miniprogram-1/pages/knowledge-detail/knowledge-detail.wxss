.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.16), transparent 24%),
    #f3f7fb;
}

.detail-card,
.empty-card,
.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.detail-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-category,
.detail-source {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.detail-category {
  color: #0f766e;
  background: rgba(20, 184, 166, 0.14);
}

.detail-source {
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.12);
}

.detail-title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.detail-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-content,
.empty-card {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}
