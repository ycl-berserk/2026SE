page {
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  background: #f2f5f9;
  color: #0f172a;
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: normal;
  background: transparent;
}

button::after {
  border: none;
}
